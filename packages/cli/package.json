{
  "name": "agentgg",
  "version": "0.0.1",
  "description": "AI-powered SAST CLI with modular, community-installable agents",
  "license": "LGPL-2.1-or-later",
  "type": "module",
  "bin": {
    "agentgg": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": ["dist", "scripts", "README.md", "LICENSE", "NOTICE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:bundle": "tsc -p tsconfig.json && node scripts/bundle-viewer.mjs",
    "clean": "rimraf dist",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build:bundle"
  },
  "dependencies": {
    "@agentgg/agents": "*",
    "@agentgg/core": "*",
    "adm-zip": "^0.5.16",
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@anthropic-ai/claude-agent-sdk": "0.2.119",
    "@inquirer/prompts": "^7.0.0",
    "ai": "^4.0.0",
    "commander": "^13.0.0",
    "minimatch": "^10.0.0",
    "ollama-ai-provider": "^1.0.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.0"
  }
}
