{
  "name": "agentgg-monorepo",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "description": "Agentic SAST scanner — white box, CI-ready, multi-provider. Reasoning where regex falls short.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/agentgg-dev/agentgg"
  },
  "scripts": {
    "build": "tsc --build",
    "agentgg": "tsx packages/cli/src/cli.ts",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": [
    "security",
    "sast",
    "vulnerability",
    "scanner",
    "ai",
    "llm",
    "static-analysis"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
